---
layout: base.njk
navPage: home
altUrl: /es/
---

<section class="hero">
  <div class="container">
    <h1>{{ t.home.hero }}</h1>
    <p class="hero-sub">{{ t.home.heroSub }}</p>
    <p class="hero-text">{{ t.home.heroText }}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2>{{ t.home.services }}</h2>
    <ul class="schedule">
      {% for item in t.home.servicesSchedule %}
      <li><span class="schedule-day">{{ item.day }}</span> <span class="schedule-time">{{ item.time }}</span></li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <h2>{{ t.home.location }}</h2>
    <p>{{ t.home.locationText }}</p>
    <div class="map-wrapper">
      <iframe
        src="{{ site.mapsEmbedUrl }}"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="{{ t.home.location }}"
      ></iframe>
    </div>
  </div>
</section>
