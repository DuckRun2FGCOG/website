---
layout: base.njk
pagination:
  data: i18n
  size: 1
  alias: locale
permalink: "/{{ locale.code }}/"
navPage: home
eleventyExcludeFromCollections: true
---

{# Hero — Foto layout #}
<section class="hero">
  <div class="hero-photo" style="background-image: url('{{ "/assets/images/exterior-street.jpg" | url }}');">
    <div class="hero-photo-inner">
      <div class="container">
        <p class="hero-eyebrow">{{ locale.home.eyebrow }}</p>
        <h1 class="hero-title">{{ locale.home.title_a }} <em>{{ locale.home.title_em }}</em>.</h1>
        <p class="hero-sub">{{ locale.home.sub }}</p>
      </div>
    </div>
  </div>
</section>

{# Service times #}
<section class="services">
  <div class="container">
    <div class="section-head" style="margin-bottom: 56px; padding-top: clamp(60px, 7vw, 100px);">
      <span class="eyebrow">{{ locale.home.services_eyebrow }}</span>
      <div>
        <h2>{{ locale.home.services_title }}</h2>
        <p class="lede" style="margin-top: 16px;">{{ locale.home.services_lede }}</p>
      </div>
    </div>
  </div>
  <div class="container">
    <div class="services-grid" style="border: 1px solid var(--rule); border-radius: 2px; margin-bottom: clamp(60px, 7vw, 100px); background: var(--paper); grid-template-columns: repeat(2, 1fr);">
      {% for svc in locale.home.services %}
      <div class="service-card">
        <p class="service-day">{{ svc.day }}</p>
        <p class="service-time">{{ svc.time }}</p>
        <p class="service-name">{{ svc.name }}</p>
        <p class="service-desc">{{ svc.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# Welcome / About preview #}
<section class="section">
  <div class="container">
    <div class="welcome">
      <div class="welcome-body">
        <p class="eyebrow" style="margin-bottom: 18px;">{{ locale.home.welcome_eyebrow }}</p>
        <h2 style="margin-bottom: 32px;">
          {{ locale.home.welcome_title_a }}<em style="color: var(--red); font-style: italic;">{{ locale.home.welcome_title_em }}</em>{{ locale.home.welcome_title_b }}
        </h2>
        <p>{{ locale.home.welcome_p1 }}</p>
        <p>{{ locale.home.welcome_p2 }}</p>
        <a class="btn" href="{{ ("/" + locale.code + "/" + locale.slugs.about + "/") | url }}" style="margin-top: 16px;">
          {{ locale.home.welcome_cta }} <span class="arrow">→</span>
        </a>
      </div>
      <div class="welcome-aside">
        <img src="{{ "/assets/images/fellowship-meal.jpg" | url }}" alt="Congregation eating together" width="600" height="750">
        <p class="caption">Cena de celebración · Duck Run 2</p>
      </div>
    </div>
  </div>
</section>

{# Visit preview #}
<section class="section section-paper">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.home.visit_eyebrow }}</span>
      <div>
        <h2>{{ locale.home.visit_title }}</h2>
        <p class="lede" style="margin-top: 16px;">{{ locale.home.visit_lede }}</p>
        <a class="btn btn-ghost" href="{{ ("/" + locale.code + "/" + locale.slugs.visit + "/") | url }}" style="margin-top: 24px;">
          {{ locale.home.visit_cta }} <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

{# Location #}
<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.home.location_eyebrow }}</span>
      <h2>{{ locale.home.location_title }}</h2>
    </div>
    <div class="location">
      <div class="location-text">
        <div class="eyebrow" style="margin-bottom: 16px;">Duck Run 2 · Cayo</div>
        <div class="addr">{{ locale.home.location_addr }}</div>
        <p class="note" style="margin-top: 24px;">{{ locale.home.location_note }}</p>
        <a class="btn" href="https://maps.app.goo.gl/W1ntW6Qxg7JHGXfr7" target="_blank" rel="noreferrer" style="margin-top: 24px;">
          {{ locale.home.location_cta }} <span class="arrow">→</span>
        </a>
      </div>
      <div class="location-map">
        <iframe
          src="{{ site.mapsEmbedUrl }}"
          width="100%"
          height="100%"
          style="border:0; min-height:360px; display:block;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="{{ locale.home.location_title }}"
        ></iframe>
      </div>
    </div>
  </div>
</section>

{# Verse pull-quote #}
<section class="verse">
  <div class="container">
    <div class="verse-mark">"</div>
    <p class="verse-text">{{ locale.home.verse }}</p>
    <p class="verse-cite">{{ locale.home.verse_cite }}</p>
  </div>
</section>

{# Gallery strip #}
<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.home.gallery_eyebrow }}</span>
      <h2>{{ locale.home.gallery_title }}</h2>
    </div>
    <div class="gallery-grid">
      <a class="gallery-item g1" href="{{ ("/" + locale.code + "/" + locale.slugs.gallery + "/") | url }}">
        <img src="{{ "/assets/images/sanctuary-center.jpg" | url }}" alt="Sanctuary" loading="lazy">
        <span class="gcap">{% if locale.code == "es" %}El santuario{% else %}The sanctuary{% endif %}</span>
      </a>
      <a class="gallery-item g2" href="{{ ("/" + locale.code + "/" + locale.slugs.gallery + "/") | url }}">
        <img src="{{ "/assets/images/worship-singing.jpg" | url }}" alt="Worship" loading="lazy">
        <span class="gcap">{% if locale.code == "es" %}Adoración{% else %}Worship{% endif %}</span>
      </a>
      <a class="gallery-item g3" href="{{ ("/" + locale.code + "/" + locale.slugs.gallery + "/") | url }}">
        <img src="{{ "/assets/images/exterior-right.jpg" | url }}" alt="Covered patio" loading="lazy">
        <span class="gcap">{% if locale.code == "es" %}Patio cubierto{% else %}Covered patio{% endif %}</span>
      </a>
      <a class="gallery-item g4" href="{{ ("/" + locale.code + "/" + locale.slugs.gallery + "/") | url }}">
        <img src="{{ "/assets/images/fellowship-meal.jpg" | url }}" alt="Fellowship meal" loading="lazy">
        <span class="gcap">{% if locale.code == "es" %}Compartir{% else %}Sharing a meal{% endif %}</span>
      </a>
      <a class="gallery-item g5" href="{{ ("/" + locale.code + "/" + locale.slugs.gallery + "/") | url }}">
        <img src="{{ "/assets/images/exterior-field.jpg" | url }}" alt="The grounds" loading="lazy">
        <span class="gcap">{% if locale.code == "es" %}El terreno{% else %}The grounds{% endif %}</span>
      </a>
    </div>
    <div style="margin-top: 32px; text-align: center;">
      <a class="btn btn-ghost" href="{{ ("/" + locale.code + "/" + locale.slugs.gallery + "/") | url }}">
        {{ locale.home.gallery_cta }} <span class="arrow">→</span>
      </a>
    </div>
  </div>
</section>
