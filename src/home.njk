---
layout: base.njk
pagination:
  data: i18n
  size: 1
  alias: locale
permalink: "/{{ locale.code }}/"
navPage: home
eleventyExcludeFromCollections: true
---

{# Hero #}
<section class="hero">
  <div class="hero-photo" style="background-image: url('{{ "/assets/images/exterior-logo.jpg" | url }}');">
    <div class="hero-photo-inner">
      <div class="container">
        <p class="hero-eyebrow">{{ locale.home.eyebrow }}</p>
        <h1 class="hero-title">{{ locale.home.title_a }}<br><em>{{ locale.home.title_em }}</em></h1>
        <p class="hero-sub">{{ locale.home.sub }}</p>
      </div>
    </div>
  </div>
</section>

{# Service times #}
<section class="services section-paper">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.home.services_eyebrow }}</span>
      <div>
        <h2>{{ locale.home.services_title }}</h2>
        <p class="lede" style="margin-top:16px;">{{ locale.home.services_lede }}</p>
      </div>
    </div>
    <div class="services-grid" style="grid-template-columns: repeat(2, 1fr);">
      {% for svc in locale.home.services %}
      <div class="service-card">
        <p class="service-day">{{ svc.day }}</p>
        <p class="service-time">{{ svc.time }}</p>
        <p class="service-name">{{ svc.name }}</p>
        <p class="service-desc">{{ svc.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# Welcome / About preview #}
<section class="section">
  <div class="container">
    <div class="welcome">
      <div class="welcome-body">
        <p class="eyebrow" style="margin-bottom:20px;">{{ locale.home.welcome_eyebrow }}</p>
        <h2>{{ locale.home.welcome_title_a }}<em style="font-style:italic;color:var(--red);">{{ locale.home.welcome_title_em }}</em>{{ locale.home.welcome_title_b }}</h2>
        <p style="margin-top:32px;">{{ locale.home.welcome_p1 }}</p>
        <p>{{ locale.home.welcome_p2 }}</p>
        <a class="btn" href="{{ ("/" + locale.code + "/" + locale.slugs.about + "/") | url }}" style="margin-top:24px;">
          {{ locale.home.welcome_cta }} <span class="arrow">→</span>
        </a>
      </div>
      <div class="welcome-aside">
        <img src="{{ "/assets/images/congregation-seated.jpg" | url }}" alt="Congregation seated during service" width="600" height="750">
        <p class="caption">Duck Run 2, Cayo · Belice</p>
      </div>
    </div>
  </div>
</section>

{# Verse pull-quote #}
<section class="verse">
  <div class="container">
    <div class="verse-mark">"</div>
    <p class="verse-text">{{ locale.home.verse }}</p>
    <p class="verse-cite">{{ locale.home.verse_cite }}</p>
  </div>
</section>

{# Gallery strip #}
<section class="section section-paper">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.home.gallery_eyebrow }}</span>
      <h2>{{ locale.home.gallery_title }}</h2>
    </div>
    <div class="gallery-grid">
      <div class="gallery-item g1">
        <img src="{{ "/assets/images/worship-singing.jpg" | url }}" alt="Worship and singing" loading="lazy">
        <span class="gcap">{{ locale.home.gallery_eyebrow }}</span>
      </div>
      <div class="gallery-item g2">
        <img src="{{ "/assets/images/choir.jpg" | url }}" alt="Church choir" loading="lazy">
      </div>
      <div class="gallery-item g3">
        <img src="{{ "/assets/images/fellowship-meal.jpg" | url }}" alt="Fellowship meal" loading="lazy">
      </div>
      <div class="gallery-item g4">
        <img src="{{ "/assets/images/sanctuary-center.jpg" | url }}" alt="Church sanctuary" loading="lazy">
      </div>
      <div class="gallery-item g5">
        <img src="{{ "/assets/images/sanctuary-side.jpg" | url }}" alt="Sanctuary side view" loading="lazy">
      </div>
    </div>
    <div style="margin-top:40px;">
      <a class="btn btn-ghost" href="{{ ("/" + locale.code + "/" + locale.slugs.gallery + "/") | url }}">
        {{ locale.home.gallery_title }} <span class="arrow">→</span>
      </a>
    </div>
  </div>
</section>

{# Visit preview #}
<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.home.visit_eyebrow }}</span>
      <div>
        <h2>{{ locale.home.visit_title }}</h2>
        <p class="lede" style="margin-top:16px;">{{ locale.home.visit_lede }}</p>
        <a class="btn" href="{{ ("/" + locale.code + "/" + locale.slugs.visit + "/") | url }}" style="margin-top:24px;">
          {{ locale.home.visit_cta }} <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

{# Location #}
<section class="section section-paper">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.home.location_eyebrow }}</span>
      <h2>{{ locale.home.location_title }}</h2>
    </div>
    <div class="location">
      <div class="location-text">
        <h3>{{ locale.home.location_title }}</h3>
        <p class="addr">{{ locale.home.location_addr }}</p>
        <p class="note">{{ locale.home.location_note }}</p>
        <a class="btn" href="https://maps.app.goo.gl/vCCnfgUzC3SFZ5gM8" target="_blank" rel="noreferrer" style="margin-top:28px;">
          {{ locale.home.location_cta }} <span class="arrow">→</span>
        </a>
      </div>
      <div class="location-map">
        <iframe
          src="{{ site.mapsEmbedUrl }}"
          width="100%"
          height="100%"
          style="border:0; min-height:360px; display:block;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="{{ locale.home.location_title }}"
        ></iframe>
      </div>
    </div>
  </div>
</section>
