---
layout: base.njk
pagination:
  data: i18n
  size: 1
  alias: locale
permalink: "/{{ locale.code }}/{{ locale.slugs.contact }}/"
navPage: contact
eleventyExcludeFromCollections: true
eleventyComputed:
  pageTitle: "{{ locale.nav.contact }}"
---

{# Page header #}
<div class="page-head">
  <div class="container">
    <p class="eyebrow">{{ locale.contact.eyebrow }}</p>
    <h1>{{ locale.contact.title_a }}{{ locale.contact.title_b }}</h1>
    <p class="sub">{{ locale.contact.sub }}</p>
  </div>
</div>

{# Contact grid #}
<section class="section section-paper">
  <div class="container">
    <div class="contact-grid">

      {# Contact info #}
      <div>
        <div class="contact-item">
          <p class="lbl">{{ locale.contact.fields.addr }}</p>
          <p class="val">{{ locale.contact.fields.addr_val }}</p>
        </div>
        <div class="contact-item">
          <p class="lbl">{{ locale.contact.fields.pastor }}</p>
          <p class="val">{{ locale.contact.fields.pastor_val }}</p>
        </div>
        <div class="contact-item">
          <p class="lbl">{{ locale.contact.fields.phone }}</p>
          <p class="val"><a href="tel:+5016131697">{{ locale.contact.fields.phone_val }}</a></p>
        </div>
        <div class="contact-item">
          <p class="lbl">{{ locale.contact.fields.email }}</p>
          <p class="val"><a href="mailto:{{ locale.contact.fields.email_val }}">{{ locale.contact.fields.email_val }}</a></p>
        </div>
        <div class="contact-item">
          <p class="lbl">{{ locale.contact.fields.denom }}</p>
          <p class="val">{{ locale.contact.fields.denom_val }}</p>
        </div>
        <div class="contact-item">
          <p class="lbl">{{ locale.contact.fields.social }}</p>
          <p class="val">
            <a href="https://www.facebook.com/fgcogbz" target="_blank" rel="noreferrer">{{ locale.contact.fields.social_val }}</a>
          </p>
        </div>
      </div>

      {# Contact form — Formspree via fetch #}
      <div>
        <h2 style="font-size:clamp(22px,2.4vw,30px);margin-bottom:32px;">{{ locale.contact.form_title }}</h2>

        <div id="contact-success" hidden style="text-align:center;padding:48px 24px;">
          <p style="font-size:48px;margin:0 0 16px;">✓</p>
          <p style="font-family:var(--sans);font-size:18px;font-weight:600;color:var(--ink);margin:0 0 8px;">{{ locale.contact.form_success }}</p>
          <p style="font-family:var(--sans);font-size:14px;color:var(--ink-3);margin:0;">{{ locale.contact.form_note }}</p>
        </div>

        <form id="contact-form" style="display:flex;flex-direction:column;gap:16px;">
          <div>
            <label for="contact-name" style="display:block;font-family:var(--sans);font-size:11px;letter-spacing:0.18em;text-transform:uppercase;font-weight:700;color:var(--ink-3);margin-bottom:8px;">{{ locale.contact.form_name }}</label>
            <input id="contact-name" name="name" type="text" required style="width:100%;padding:12px 14px;border:1px solid var(--rule);background:var(--paper);font-family:var(--sans);font-size:16px;color:var(--ink);outline:none;">
          </div>
          <div>
            <label for="contact-email" style="display:block;font-family:var(--sans);font-size:11px;letter-spacing:0.18em;text-transform:uppercase;font-weight:700;color:var(--ink-3);margin-bottom:8px;">{{ locale.contact.form_email }}</label>
            <input id="contact-email" name="email" type="email" required style="width:100%;padding:12px 14px;border:1px solid var(--rule);background:var(--paper);font-family:var(--sans);font-size:16px;color:var(--ink);outline:none;">
          </div>
          <div>
            <label for="contact-msg" style="display:block;font-family:var(--sans);font-size:11px;letter-spacing:0.18em;text-transform:uppercase;font-weight:700;color:var(--ink-3);margin-bottom:8px;">{{ locale.contact.form_msg }}</label>
            <textarea id="contact-msg" name="message" rows="5" required style="width:100%;padding:12px 14px;border:1px solid var(--rule);background:var(--paper);font-family:var(--sans);font-size:16px;color:var(--ink);outline:none;resize:vertical;"></textarea>
          </div>
          <p id="contact-error" hidden style="font-family:var(--sans);font-size:14px;color:#c0392b;margin:0;">{{ locale.contact.form_error }}</p>
          <button id="contact-submit" class="btn" type="submit">{{ locale.contact.form_send }} <span class="arrow">→</span></button>
          <p style="font-size:13px;color:var(--ink-3);margin:0;">{{ locale.contact.form_note }}</p>
        </form>

        <script>
          (function () {
            var form = document.getElementById('contact-form');
            var success = document.getElementById('contact-success');
            var error = document.getElementById('contact-error');
            var btn = document.getElementById('contact-submit');
            if (!form) return;
            form.addEventListener('submit', function (e) {
              e.preventDefault();
              error.hidden = true;
              btn.disabled = true;
              fetch('https://formspree.io/f/meenypol', {
                method: 'POST',
                body: new FormData(form),
                headers: { Accept: 'application/json' }
              }).then(function (res) {
                if (res.ok) {
                  form.hidden = true;
                  success.hidden = false;
                } else {
                  error.hidden = false;
                  btn.disabled = false;
                }
              }).catch(function () {
                error.hidden = false;
                btn.disabled = false;
              });
            });
          })();
        </script>
      </div>

    </div>
  </div>
</section>
