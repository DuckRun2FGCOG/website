<header class="site-header">
  <div class="container">
    <a class="site-name" href="{{ '/' + lang + '/' | url }}">{{ site.name }}</a>

    <button class="nav-toggle" aria-label="{{ t.nav.toggleMenu }}" aria-expanded="false" aria-controls="main-nav">
      <span class="hamburger"></span>
    </button>

    <nav id="main-nav" class="main-nav" aria-label="Main navigation">
      <ul>
        <li><a href="{{ '/' + lang + '/' | url }}" {% if navPage == 'home' %}class="active"{% endif %}>{{ t.nav.home }}</a></li>
        <li><a href="{{ '/' + lang + '/' + t.nav.aboutSlug + '/' | url }}" {% if navPage == 'about' %}class="active"{% endif %}>{{ t.nav.about }}</a></li>
        <li><a href="{{ '/' + lang + '/' + t.nav.contactSlug + '/' | url }}" {% if navPage == 'contact' %}class="active"{% endif %}>{{ t.nav.contact }}</a></li>
      </ul>
      <a class="lang-switch" href="{{ altUrl | url }}" lang="{{ altLang }}">{{ altLangLabel }}</a>
    </nav>
  </div>
</header>
