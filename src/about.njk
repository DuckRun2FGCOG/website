---
layout: base.njk
pagination:
  data: i18n
  size: 1
  alias: locale
permalink: "/{{ locale.code }}/{{ locale.slugs.about }}/"
navPage: about
eleventyExcludeFromCollections: true
eleventyComputed:
  pageTitle: "{{ locale.nav.about }}"
---

{# Page header #}
<div class="page-head">
  <div class="container">
    <p class="eyebrow">{{ locale.about.eyebrow }}</p>
    <h1>{{ locale.about.title_a }}<em>{{ locale.about.title_em }}</em>{{ locale.about.title_b }}</h1>
    <p class="sub">{{ locale.about.sub }}</p>
  </div>
</div>

{# About sections #}
<section class="section section-paper">
  <div class="container">
    {% for sec in locale.about.sections %}
    <div class="about-cols">
      <div class="label">{{ sec.label }}</div>
      <div class="body">
        {% for para in sec.body %}
        <p>{{ para }}</p>
        {% endfor %}
      </div>
    </div>
    {% endfor %}

    {# Pastor cards #}
    <p class="eyebrow" style="margin-top:clamp(48px,6vw,80px); margin-bottom:0;">{{ locale.about.pastors_eyebrow }}</p>
    {% for pastor in locale.about.pastors %}
    <div class="pastor-card">
      <div class="pastor-photo">
        <img src="{{ ('/assets/images/' + pastor.photo) | url }}" alt="{{ pastor.name }}" style="{{ pastor.photo_style }}">
      </div>
      <div class="pastor-body">
        <p class="name">{{ pastor.name }}</p>
        <p class="role">{{ pastor.role }}</p>
        <p class="bio">{{ pastor.bio }}</p>
        <p class="quote">{{ pastor.quote }}</p>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

{# Beliefs grid #}
<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.about.beliefs_eyebrow }}</span>
      <h2>{{ locale.about.beliefs_title }}</h2>
    </div>
    <div class="beliefs">
      {% for belief in locale.about.beliefs %}
      <div class="belief">
        <p class="ix">{{ loop.index }}</p>
        <h4>{{ belief.h }}</h4>
        <p>{{ belief.b }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
