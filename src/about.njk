---
layout: base.njk
pagination:
  data: i18n
  size: 1
  alias: locale
permalink: "/{{ locale.code }}/{{ locale.slugs.about }}/"
navPage: about
eleventyExcludeFromCollections: true
eleventyComputed:
  pageTitle: "{{ locale.nav.about }}"
---

{# Page header #}
<div class="page-head">
  <div class="container">
    <p class="eyebrow">{{ locale.about.eyebrow }}</p>
    <h1>{{ locale.about.title_a }}<em>{{ locale.about.title_em }}</em>{{ locale.about.title_b }}</h1>
    <p class="sub">{{ locale.about.sub }}</p>
  </div>
</div>

{# About sections #}
<section class="section section-paper">
  <div class="container">
    {% for sec in locale.about.sections %}
    <div class="about-cols">
      <div class="label">{{ sec.label }}</div>
      <div class="body">
        {% for para in sec.body %}
        <p>{{ para }}</p>
        {% endfor %}
      </div>
    </div>
    {% endfor %}

    {# Vision / Mission #}
    <div class="vm-grid" style="margin-top:clamp(48px,6vw,80px);">
      <div class="vm-card">
        <div class="vm-label">{{ locale.about.vision_eyebrow }}:</div>
        <div class="vm-text">{{ locale.about.vision }}</div>
      </div>
      <div class="vm-card">
        <div class="vm-label">{{ locale.about.mission_eyebrow }}:</div>
        <div class="vm-text">{{ locale.about.mission }}</div>
      </div>
    </div>

    {# Pastor cards #}
    <p class="eyebrow" style="margin-top:clamp(48px,6vw,80px); margin-bottom:0;">{{ locale.about.pastors_eyebrow }}</p>
    {% for pastor in locale.about.pastors %}
    <div class="pastor-card">
      <div class="pastor-photo">
        <img src="{{ ('/assets/images/' + pastor.photo) | url }}" alt="{{ pastor.name }}" style="{{ pastor.photo_style }}">
      </div>
      <div class="pastor-body">
        <p class="name">{{ pastor.name }}</p>
        <p class="role">{{ pastor.role }}</p>
        <p class="bio">{{ pastor.bio }}</p>
        <p class="quote">{{ pastor.quote }}</p>
        <a class="pastor-more-link" href="{{ ('/' + locale.code + '/' + pastor.page_slug + '/') | url }}">{{ locale.about.pastor_more }} →</a>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

{# Beliefs grid #}
<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.about.beliefs_eyebrow }}</span>
      <h2>{{ locale.about.beliefs_title }}</h2>
    </div>
    <div class="beliefs">
      {% for belief in locale.about.beliefs %}
      <div class="belief">
        <p class="ix">{{ loop.index }}</p>
        <h4>{{ belief.h }}</h4>
        {% if belief.refs or belief.verses %}
        <details class="belief-details">
          <summary>{{ locale.about.verses_toggle }}</summary>
          <div class="belief-verses">
            {% if belief.refs %}<p class="refs">{{ belief.refs }}</p>{% endif %}
            {% if belief.verses %}<p class="verse-text">{{ belief.verses }}</p>{% endif %}
          </div>
        </details>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
