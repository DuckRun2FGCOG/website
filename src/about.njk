---
layout: base.njk
pagination:
  data: i18n
  size: 1
  alias: locale
permalink: "/{{ locale.code }}/{{ locale.slugs.about }}/"
navPage: about
eleventyExcludeFromCollections: true
eleventyComputed:
  pageTitle: "{{ locale.nav.about }}"
---

{# Page header #}
<div class="page-head">
  <div class="container">
    <p class="eyebrow">{{ locale.about.eyebrow }}</p>
    <h1>{{ locale.about.title_a }}<em>{{ locale.about.title_em }}</em>{{ locale.about.title_b }}</h1>
    <p class="sub">{{ locale.about.sub }}</p>
  </div>
</div>

{# About sections #}
<section class="section section-paper">
  <div class="container">
    {% for sec in locale.about.sections %}
    <div class="about-cols">
      <div class="label">{{ sec.label }}</div>
      <div class="body">
        {% for para in sec.body %}
        <p>{{ para }}</p>
        {% endfor %}
      </div>
    </div>
    {% endfor %}

    {# Pastor card #}
    <div class="pastor-card" style="margin-top:clamp(48px,6vw,80px);">
      <div class="pastor-photo" aria-label="Pastor Ismael Rodríguez — photo coming soon">
        <span>Photo<br>coming soon</span>
      </div>
      <div class="pastor-body">
        <p class="eyebrow" style="margin-bottom:12px;">{{ locale.about.pastor_eyebrow }}</p>
        <p class="name">{{ locale.about.pastor_name }}</p>
        <p class="role">{{ locale.about.pastor_role }}</p>
        <p class="quote">{{ locale.about.pastor_quote }}</p>
      </div>
    </div>
  </div>
</section>

{# Beliefs grid #}
<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ locale.about.beliefs_eyebrow }}</span>
      <h2>{{ locale.about.beliefs_title }}</h2>
    </div>
    <div class="beliefs">
      {% for belief in locale.about.beliefs %}
      <div class="belief">
        <p class="ix">{{ loop.index }}</p>
        <h4>{{ belief.h }}</h4>
        <p>{{ belief.b }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
